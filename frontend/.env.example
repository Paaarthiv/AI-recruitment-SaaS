# ============================================================
# Lumina Nexus — Frontend Environment Variables
# Copy to .env.local for local development.
# Never commit .env.local to version control.
# ============================================================

# ----- API -----
# URL of the Django backend API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----- App -----
# Application base URL (used for redirects, SEO, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Supabase (used from Sprint 3 onwards) -----
# Public project values only. Do not commit real keys, even anon keys.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
