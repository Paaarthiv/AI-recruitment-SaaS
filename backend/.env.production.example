# ── SkillScout backend — production env (Railway) ──
# Copy these into your Railway service "Variables". Do NOT commit real values.

# Core
DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=False
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=CHANGE_ME

# Hosts / CORS / CSRF  (use your real Railway + Vercel domains)
DJANGO_ALLOWED_HOSTS=your-api.up.railway.app
DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app,https://your-api.up.railway.app

# Cross-site cookies (frontend on Vercel, backend on Railway = different sites)
COOKIE_SAMESITE=None
AUTH_COOKIE_SECURE=true

# Database & Redis — reference Railway's services:
#   DATABASE_URL = ${{ Postgres.DATABASE_URL }}
#   REDIS_URL    = ${{ Redis.REDIS_URL }}
DATABASE_URL=
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# LLM (hosted Ollama / Qwen — NOT self-hosted on Railway)
OLLAMA_BASE_URL=https://your-ollama-endpoint
LLM_MODEL=qwen3-coder:480b
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# Supabase storage (resumes)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=resumes

# Optional email (notifications)
DEFAULT_FROM_EMAIL=no-reply@skillscout.local
