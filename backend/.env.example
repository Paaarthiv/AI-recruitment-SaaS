# ============================================================
# Lumina Nexus — Backend Environment Variables
# Copy to .env for local development.
# Never commit .env to version control.
# ============================================================

# ----- Core -----
APP_ENV=development
DEBUG=True

# ----- Django -----
DJANGO_SECRET_KEY=change-me-in-development-use-50-char-random-string
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,django
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----- Database -----
POSTGRES_DB=recruitment_db
POSTGRES_USER=recruit_user
POSTGRES_PASSWORD=changeme
DATABASE_URL=

# ----- Redis / Celery -----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ----- JWT (Sprint 1: configured. Implementation → Sprint 2) -----
# ACCESS_TOKEN_LIFETIME and REFRESH_TOKEN_LIFETIME are set in settings/base.py
# Override here only if you need non-default values in development.
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
# JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ----- Local AI (Sprint 4+) -----
OLLAMA_BASE_URL=http://ollama:11434
# Primary resume-parsing LLM. Avoid gpt-oss:20b on Ollama Cloud — it returns
# empty output there (harmony channels are dropped server-side).
LLM_MODEL=qwen3-coder:480b
LLM_FALLBACK_MODELS=gemma3:12b,gemma3:4b
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384
# Options: sentence_transformers (real semantic, default), ollama, local_hashing (placeholder)
EMBEDDING_PROVIDER=sentence_transformers

# ----- Supabase (Sprint 3+) -----
# Keep service role keys server-side ONLY. Never expose to the frontend.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=resumes
SUPABASE_CLI_VERSION=2.26.9
